---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import PhoneMockup from '~/components/ui/PhoneMockup.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'HippoChat — HIPAA-Compliant Messaging for Clinical Teams',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '/contact',
      },
      { text: 'Learn more', href: '#use-cases' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">HippoChat</span> is HIPAA-Compliant Messaging for <span class="text-accent dark:text-white">Clinical Teams</span> Across Organizations
    </Fragment>

    <Fragment slot="subtitle">
      Share PHI securely with external nurses, answering services, and partner clinicians—while preserving the security of your EHR, texting system, and internal infrastructure.
    </Fragment>

    <Fragment slot="image">
      <PhoneMockup />
    </Fragment>
  </Hero>

  <!-- Built for Cross-Organizational Care -->
  <Features
    id="features"
    tagline="Purpose-Built"
    title="Built for Cross-Organizational Care"
    columns={3}
    items={[
      {
        title: 'Separate Users, Shared Communication',
        description: 'Each organization keeps its own users and boundaries—you collaborate across them.',
        icon: 'tabler:building',
      },
      {
        title: 'Know Who Said What, When',
        description: 'Every message is logged so you always know who sent it, when, and who saw it.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Permissions That Fit Your Workflow',
        description: 'Control who can see and do what, matched to how your team actually works.',
        icon: 'tabler:lock',
      },
      {
        title: 'Keep Records on Your Terms',
        description: 'Keep messages as long or as short as your compliance requirements need.',
        icon: 'tabler:clock',
      },
      {
        title: 'Onboard Partners in Minutes',
        description: 'Invite external clinicians and they can start messaging right away.',
        icon: 'tabler:user-plus',
        callToAction: { text: 'Learn more', href: '/product' },
      },
      {
        title: 'BAA Available',
        description: 'Business Associate Agreements ready for every deployment.',
        icon: 'tabler:file-certificate',
        callToAction: { text: 'Learn more', href: '/product' },
      },
    ]}
  />

  <!-- Why HippoChat — Pain to Value -->
  <Content
    isReversed
    tagline="Better Together"
    title='Why <span class="text-accent dark:text-white">HippoChat</span>?'
    items={[
      {
        title: 'Replace SMS and personal phones with secure, compliant messaging',
      },
      {
        title: 'Real messaging with audit trails instead of pager codes and callbacks',
      },
      {
        title: 'Messaging designed for multiple organizations from the start',
      },
      {
        title: 'Connect external partners securely—on their own terms, outside your systems',
      },
    ]}
    image={{
      src: '~/assets/images/why-hippochat.png',
      alt: 'HippoChat secure platform diagram showing nurse and provider communication with encrypted messaging',
      width: 768,
      height: 512,
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2"><span class="text-accent dark:text-white">HippoChat</span> Connects Teams Across Systems</h3>
      Secure messaging that works across organizational boundaries. Everyone stays on their own system while communicating seamlessly. Full auditability, full control. Designed for real-world care networks.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Common Use Cases -->
  <Features2
    id="use-cases"
    tagline="Use Cases"
    title="Common Use Cases"
    columns={2}
    items={[
      {
        title: 'Hospitals & Health Organizations',
        description: 'Coordinate care across departments, partner facilities, and external providers—all on one secure platform.',
        icon: 'tabler:building-hospital',
        callToAction: { text: 'See use case', href: '/use-cases' },
      },
      {
        title: 'Nurse Triage Services',
        description: 'Triage nurses and on-call providers communicate securely across organizations.',
        icon: 'tabler:stethoscope',
        callToAction: { text: 'See use case', href: '/use-cases' },
      },
      {
        title: 'Answering Services',
        description: 'Auditable after-hours messages replace risky phone and SMS workflows.',
        icon: 'tabler:phone',
        callToAction: { text: 'See use case', href: '/use-cases' },
      },
      {
        title: 'EMS & First Responders',
        description: 'Connect field teams with hospitals and receiving providers in real time.',
        icon: 'tabler:ambulance',
        callToAction: { text: 'See use case', href: '/use-cases' },
      },
    ]}
  />

  <!-- Who Benefits -->
  <Features
    title='Who Benefits from <span class="text-accent dark:text-white">HippoChat</span>'
    columns={2}
    items={[
      {
        title: 'Clinical Leadership',
        description: 'Faster coordination with documentation for quality review.',
        icon: 'tabler:heart-rate-monitor',
      },
      {
        title: 'Operations / Admin',
        description: 'Lower compliance risk and simple partner onboarding.',
        icon: 'tabler:settings',
      },
      {
        title: 'CIO / IT',
        description: 'Clean system boundaries—no managing outside users in your internal systems.',
        icon: 'tabler:server',
      },
      {
        title: 'Compliance / Security',
        description: 'Full audit trails, retention controls, and BAA for every deployment.',
        icon: 'tabler:shield-lock',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Fast, Compliant Communication Across Organizations
    </Fragment>

    <Fragment slot="subtitle">
      See how <span class="text-accent dark:text-white">HippoChat</span> connects your clinical teams—securely and compliantly.
    </Fragment>
  </CallToAction>
</Layout>
