---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import PhoneMockup from '~/components/ui/PhoneMockup.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import StructuredData from '~/components/common/StructuredData.astro';

const metadata = {
  title: 'Product',
  description: 'Explore HippoChat capabilities: cross-organization messaging, audit trails, configurable retention, fast onboarding, and BAA availability.',
};
---

<Layout metadata={metadata}>
  <StructuredData
    type="product"
    breadcrumbs={[
      { name: 'Home', url: '/' },
      { name: 'Product', url: '/product' },
    ]}
  />
  <!-- Hero -->
  <Hero
    tagline="Product"
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Messaging Built for <span class="text-accent dark:text-white">Cross-Organizational Care</span>
    </Fragment>

    <Fragment slot="subtitle">
      Healthcare teams span multiple organizations. HippoChat is secure messaging designed for exactly that.
    </Fragment>

    <Fragment slot="image">
      <PhoneMockup />
    </Fragment>
  </Hero>

  <!-- What HippoChat Is -->
  <Content
    tagline='What <span class="text-accent dark:text-white">HippoChat</span> Is'
    title="Purpose-Built for Cross-Organization Communication"
    image={{
      src: '~/assets/images/why-hippochat.png',
      alt: 'HippoChat secure platform diagram',
      width: 768,
      height: 512,
    }}
  >
    <Fragment slot="content">
      <p class="mb-4">
        <span class="text-accent dark:text-white">HippoChat</span> exists for the reality that clinical teams coordinate care across different systems. Not everyone is on the same EHR or messaging platform—and they don't need to be. HippoChat connects them securely.
      </p>
      <ul class="list-disc list-inside space-y-2">
        <li>Purpose-built for healthcare — <a href="/use-cases" class="text-accent hover:underline">see use cases</a></li>
        <li>Respects organizational boundaries</li>
        <li><a href="/security" class="text-accent hover:underline">Secure and auditable</a></li>
      </ul>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50 dark:bg-slate-900/30"></div>
    </Fragment>
  </Content>

  <!-- Core Capabilities -->
  <Features
    tagline="Capabilities"
    title="Core Capabilities"
    columns={3}
    items={[
      {
        title: 'Separate users, shared communication',
        description: 'Each organization keeps its own users and boundaries—you collaborate across them.',
        icon: 'tabler:building',
      },
      {
        title: 'Know who said what, when',
        description: 'Every message is logged so you always know who sent it, when, and who saw it.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Permissions that fit your workflow',
        description: 'Control who can see and do what, matched to how your team actually works.',
        icon: 'tabler:lock',
      },
      {
        title: 'Keep records on your terms',
        description: 'Keep messages as long or as short as your compliance requirements need.',
        icon: 'tabler:clock',
      },
      {
        title: 'Onboard partners in minutes',
        description: 'Invite external clinicians and they can start messaging right away.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Cloud-hosted and ready to go',
        description: 'Fully managed platform—each organization\'s data stays securely separated.',
        icon: 'tabler:cloud',
      },
    ]}
  />

  <!-- What HippoChat Replaces -->
  <Features2
    tagline="Replaces"
    title='What <span class="text-accent dark:text-white">HippoChat</span> Replaces'
    columns={2}
    items={[
      {
        title: 'SMS and personal phones',
        description: 'Move PHI off personal devices and into a secure, compliant channel.',
        icon: 'tabler:device-mobile-off',
      },
      {
        title: 'Pager systems',
        description: 'Real messaging with audit trails, not codes and callbacks.',
        icon: 'tabler:bell-off',
      },
      {
        title: 'Secure texting tools (single-org)',
        description: 'Built for multiple organizations with clear boundaries.',
        icon: 'tabler:message-off',
      },
      {
        title: '"Temporary" access to internal systems',
        description: 'Stop managing extra EHR logins for outside partners that never get cleaned up.',
        icon: 'tabler:key-off',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50/50 dark:bg-blue-950/20"></div>
    </Fragment>
  </Features2>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Request a Demo',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">See <span class="text-accent dark:text-white">HippoChat</span> in Action</Fragment>
    <Fragment slot="subtitle">
      Learn how <span class="text-accent dark:text-white">HippoChat</span> can solve your cross-organizational communication challenges.
    </Fragment>
  </CallToAction>
</Layout>
