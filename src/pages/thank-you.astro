---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Thank You',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Message Received" title="Thank You!">
    <Fragment slot="subtitle">
      We've received your message and will get back to you within 1-2 business days. In the meantime, feel free to explore more about <span class="text-accent dark:text-white">HippoChat</span>.
    </Fragment>
  </HeroText>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Back to Home',
        href: '/',
      },
    ]}
  />
</Layout>
