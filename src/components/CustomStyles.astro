---
import '@fontsource-variable/inter';
import '@fontsource-variable/plus-jakarta-sans';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Plus Jakarta Sans Variable';

    --aw-color-primary: rgb(0 82 204);
    --aw-color-secondary: rgb(0 58 140);
    --aw-color-accent: rgb(56 132 244);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Plus Jakarta Sans Variable';

    --aw-color-primary: rgb(56 132 244);
    --aw-color-secondary: rgb(0 82 204);
    --aw-color-accent: rgb(99 163 255);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: rgb(0 40 100);
      color: rgb(220 230 245);
    }
  }
</style>
